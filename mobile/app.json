{
  "expo": {
    "name": "Travel Check-in",
    "slug": "travel-checkin-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "travelcheckin",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.travelcheckin.mobile"
    },
    "android": {
      "package": "com.travelcheckin.mobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser"
    ]
  }
}
